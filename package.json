{
  "name": "vite-plugin-flatten-ns",
  "version": "0.2.1",
  "description": "Flatten namespace re-exports (export * as) into individual named exports for RSC compatibility",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "release": "npm run build && changeset publish"
  },
  "keywords": [
    "vite-plugin",
    "rsc",
    "react-server-components",
    "barrel",
    "namespace"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyb3rcore/vite-plugin-flatten-ns.git"
  },
  "dependencies": {
    "estree-walker": "^3.0.3",
    "magic-string": "^0.30.21"
  },
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/estree": "^1.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0",
    "vite": "^6.0.0"
  }
}
